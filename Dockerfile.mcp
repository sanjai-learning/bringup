FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    MCP_TRANSPORT=sse \
    MCP_PORT=8000

WORKDIR /app

COPY requirements-mcp.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY mcp ./mcp

EXPOSE 8000

CMD ["python", "mcp/zerodha_server.py"]
